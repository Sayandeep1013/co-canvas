{
  "name": "canvas-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "CanVas - realtime collaborative notes + drawing rooms",
  "scripts": {
    "dev": "pnpm --parallel --filter web --filter party dev",
    "dev:web": "pnpm --filter web dev",
    "dev:party": "pnpm --filter party run dev",
    "deploy:party": "pnpm --filter party run deploy",
    "build": "pnpm --filter web build",
    "lint": "pnpm --filter web lint"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.1.3",
  "devDependencies": {
    "playwright": "^1.61.1"
  }
}
